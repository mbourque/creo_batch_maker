! Conditional file for ModelCHECK.
! Date: 04-12-2004
# SET CONFIG FILE
IF (MODEL_UNIT EQ INCH) config=(checks.mch)(start.mcs)(inch.mcn)(status.mcq)
IF (MODEL_UNIT EQ MM) config=(checks.mch)(sstart.mcs)(mm.mcn)(status.mcq)
ELSE config=(checks.mch)(start.mcs)(mm.mcn)(status.mcq)

# OVERRIDE CHECKS
IF (NOCHECK) NOCHECK
