! Configuration file for ModelCHECK. 
!22-May-00 VA  $$1 Change back slash to forward in MC_REGEN_CONFIG_FILE
# PART MODE START PART REPORT CONFIGURATION  
PRT_DATUM_PLANE      DTM1         1
PRT_DATUM_PLANE      DTM2         2
PRT_DATUM_PLANE      DTM3         3

# ASSEMBLY MODE START PART REPORT CONFIGURATION
ASM_DATUM_PLANE      ADTM1        1
ASM_DATUM_PLANE      ADTM2        2
ASM_DATUM_PLANE      ADTM3        3

# PART INFORMATION
PRT_MODEL_NAME       LTE          LENGTH_24

PRT_UNITS_LENGTH     MM
PRT_UNITS_LENGTH     INCH
PRT_UNITS_MASS       KILOGRAM
PRT_UNITS_MASS       POUND


# ASSEMBLY INFORMATION
ASM_PARAMETER        MODEL        STR      EQ       circ
ASM_PARAMETER        PN           NONE     EQ       PDM
ASM_PARAMETER        COMPANY      STR      EQ       RAND TECHNOLOGIES
ASM_PARAMETER        EMPTY        NONE     NEQ      NULL
ASM_PARAMETER        DRAWN_BY     STR      EQ       LIST_DESIGNERS
ASM_PARAMETER        RELEASED     BOOL     EQ       YES
ASM_PARAMETER        DRAFT_ANGLE  REAL   LTE      5
ASM_PARAMETER        DRAFT_ANGLE  REAL   GTE      3
ASM_PARAMETER        DESCRIPTION  STR      NEQ      *test*
ASM_PARAMETER        MATERIAL     STR      NEQ      LIST_BAD_MATL
ASM_PARAMETER        MATERIAL     STR      EQ       PDM
ASM_PARAMETER        RC_MODEL_TYPE STR      EQ       LIST_MODEL_TYPE
ASM_PARAMETER        ENG_PRJ_NO   STR      EQ       LIST_PRJ_NO
ASM_PARAMETER        ENG_PRJ_NO   STR      EQ       PDM
ASM_PARAMETER        DEPARTMENT   STR      LTE      LENGTH_12
ASM_PARAMETER        MASS         REAL
ASM_PARAMETER        VOLUME       REAL

ASM_LAYER            AXES         BLANK    DATUM_AXIS
ASM_LAYER            CSYS         BLANK    DATUM_CSYS
ASM_LAYER            CURVES       BLANK    DATUM_CURVE
ASM_LAYER            DATUMS       BLANK    DATUM_PLANES
ASM_LAYER            DRAFT        NORMAL   DRAFT
ASM_LAYER            COSMETICS    NONE     COSMETIC_ALL

ASM_LAYER_UNWANTED  MC_LAYER1
ASM_PARAM_UNWANTED  MC_PARAM1
ASM_PARAM_MAP  MC_PARAM1 MC_PARAM2

ASM_TOL_TYPE         DIN/ISO

ASM_COMMENT          Ensures that mass parameter is set to mass property value
ASM_RELATION         MASS=mp_mass("")
ASM_COMMENT          Ensures that volume parameter is set to mass property value
ASM_RELATION         VOLUME=mp_volume("")

ASM_LAYER_MOVE       DTMS         	DATUM_PLANES
ASM_LAYER_MOVE       DTM_PLANES   	DATUM_PLANES
ASM_LAYER_MOVE       DTM_CURVES   	DATUM_CURVES
ASM_PARAM_RENAME     PDMRL      	PDMRL1
ASM_PARAM_RENAME     PN       	PN1
ASM_DATUM_RENAME     XY      		ADTM1
ASM_DATUM_RENAME     XZ      		ADTM2
ASM_DATUM_RENAME     ZY      		ADTM3

ASM_PRO_VERSION      199632

# DRAWING INFORMATION
DRW_FORMAT       		a
DRW_FORMAT       		b
DRW_FORMAT       		c
DRW_FORMAT       		d
DRW_FORMAT       		e
DRW_NOTE_FONT        	font
DRW_NOTE_FONT		FONT
DRW_NOTE_FONT	     	leroy
DRW_NOTE_FONT	     	isofont
DRW_NOTE_HEIGHT      	3.5
DRW_NOTE_HEIGHT      	5.0
DRW_NOTE_HEIGHT      	0.25
DRW_NOTE_HEIGHT      	0.2

DRW_LAYER            AXES         BLANK    DATUM_AXIS
DRW_LAYER            CSYS         BLANK    DATUM_CSYS
DRW_LAYER            CURVES       BLANK    DATUM_CURVE
DRW_LAYER            DATUMS       BLANK    DATUM_PLANES
DRW_LAYER            DRAFT_ENT    NORMAL   DRAFT_ENT

DRW_LAYER_UNWANTED  MC_LAYER1
DRW_PARAM_UNWANTED  MC_PARAM1
DRW_PARAM_MAP  MC_PARAM1 MC_PARAM2

DRW_LAYER_MOVE	   DRAFT_ENTITY 	DRAFT_ENT 

DRW_SYMBOL	     	   ASI
DRW_SYMBOL	         GEAR
DRW_SYMBOL	         DOT

DRW_TABLE_CELLS      [1,1,BOM] [4,2,Rand]
DRW_TABLE_CELLS      [1,2,Items]

DRW_NOTE_UNACC       Prescient
DRW_NOTE_UNACC       DQA

DRW_IGNORE_SHEETS    IGNORE_SHEETS     LIST_IGNORE_SHEETS

LIST_IGNORE_SHEETS   2
LIST_IGNORE_SHEETS   4

# SHEETMETAL BEND TABLE NAME LIST
SHTMTL_BTNAME        bend_1
SHTMTL_BTNAME        BEND_2

# STANDARD LIST FILE NAMES

MC_REGEN_CONFIG_FILE   text/mc_regen.mcr

